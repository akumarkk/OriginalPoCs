{
  "Serilog": {
    "Using": [ "Serilog.Sinks.OpenTelemetry" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Worker": "Warning",
        "Host": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "%LOG_DIRECTORY%/Logs/function-logs-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 5,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "OpenTelemetry",
        "Args": {
          "Endpoint": "https://%DT_TENANT%.live.dynatrace.com/api/v2/otlp/v1/logs",
          "Protocol": "HttpProtobuf",
          "Headers": {
            "Authorization": "Api-Token %DT_CONNECTION_AUTH_TOKEN%"
          }
        }
      }
    ]
  }
}
